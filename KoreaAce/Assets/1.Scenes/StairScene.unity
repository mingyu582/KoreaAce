  m_Text: "150\uCE35 \"\uAE30\uB85D 03: \uD5C8\uBB3C\uACFC \uC81C\uBB3C\"\r\n\r\n150\uCE35...
    \uB0B4 \uBAB8\uC5D0 \uBE44\uB298\uC774 \uB3CB\uAE30 \uC2DC\uC791\uD588\uB2E4.
    \uC774\uC81C \uC54C \uAC83 \uAC19\uB2E4. \uC774 \uC131\uC5D0 \uB4E4\uC5B4\uC628
    \uC790\uB4E4\uC740 \uBAA8\uB450 \uB188\uC758 \uC0C8\uB85C\uC6B4 \uD5C8\uBB3C\uC774
